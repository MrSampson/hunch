{
  "domains": {
    "backend": {
      "paths": "(^|/)(src|lib|server|api|core|store|synthesis|extractors|mcp|cli)/|\\.(ts|mts|cts|js|mjs|cjs|py|go|rs|java)$",
      "verify": "vitest|jest|pytest|go test|cargo test|tsx --test|npm (run )?test|tsc|typecheck",
      "payload": "backend.md"
    },
    "frontend": {
      "paths": "\\.(tsx|jsx|css|scss|html|vue|svelte)$|(^|/)(components|pages|site|app|ui)/",
      "verify": "vite|next (build|dev)|npm run (build|dev)|playwright|screenshot|storybook|tsc",
      "payload": "frontend.md"
    },
    "tests": {
      "paths": "(^|/)(test|tests|__tests__|e2e|spec)/|\\.(test|spec)\\.",
      "verify": "vitest|jest|pytest|tsx --test|npm (run )?test|playwright",
      "payload": "qa.md"
    },
    "infra": {
      "paths": "Dockerfile|docker-compose|\\.tf$|\\.tfvars$|(^|/)(\\.github|k8s|helm|terraform|infra|deploy)/|\\.ya?ml$",
      "verify": "terraform (plan|validate)|docker (build|compose)|kubectl .*--dry-run|helm (lint|template)|act(ionlint)?|npm run build",
      "payload": "infra.md"
    }
  }
}
